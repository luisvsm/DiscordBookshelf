DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id_here
# Optional: restrict command registration to a single guild during development
GUILD_ID=
# Optional: how long to keep decrypted passwords cached in memory (default: 3 days)
PASSWORD_TTL_DAYS=
# Optional: require all users to set an encryption password when connecting (default: true)
REQUIRE_ENCRYPTION=
